<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (ws://, http://) for LAN device management.
         BuzzPi agents run on local Pis without TLS.
         Will tighten to domain-specific config when TLS is added. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
